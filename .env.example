# Monorepo: um `.env.local` na raiz costuma bastar (backend, temporal e Prisma em front/ leem daqui).
# Postgres — local com `docker compose up`: postgresql://liquida:liquida@localhost:5432/liquida?schema=public
DATABASE_URL="postgresql://user:pass@localhost:5432/liquida?schema=public"

# Next.js: encaminha /api/* para o backend FastAPI (dev: uvicorn em 8000). Em produção, URL pública ou interna da API Python.
API_PROXY_URL="http://127.0.0.1:8000"

# Criptografia de refresh token (openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=""

# Magalu OAuth (servidor)
MAGALU_CLIENT_ID=""
MAGALU_CLIENT_SECRET=""
# Produção / iframe Geraldo:
MAGALU_REDIRECT_URI="https://geraldo-restaurantes.aiqfome.digital/apps-e-integracoes/auth/callback"
# Teste local (sem iframe): cadastre a MESMA URL no app Magalu ID (porta = `npm run dev`):
# MAGALU_REDIRECT_URI="http://localhost:3000/auth/magalu/callback"
# MAGALU_TOKEN_URL=https://id.magalu.com/oauth/token

# Magalu + postMessage (browser — expostos ao cliente)
NEXT_PUBLIC_MAGALU_CLIENT_ID=""
NEXT_PUBLIC_MAGALU_REDIRECT_URI="https://geraldo-restaurantes.aiqfome.digital/apps-e-integracoes/auth/callback"
# Local: idêntico a MAGALU_REDIRECT_URI
# NEXT_PUBLIC_MAGALU_REDIRECT_URI="http://localhost:3000/auth/magalu/callback"
NEXT_PUBLIC_POSTMESSAGE_ORIGINS="https://geraldo-restaurantes.aiqfome.digital,http://localhost:3000"

# CSP: quem pode embutir o app em iframe
ALLOWED_FRAME_ANCESTORS="'self' https://geraldo-restaurantes.aiqfome.digital"

# Dev: permite POST /api/auth/magalu/token **sem** code (botão "Entrar (dev)").
# Com `code` do Magalu, o backend **sempre** troca o token de verdade — não desliga o OAuth real.
SKIP_OAUTH_VALIDATION="false"
NEXT_PUBLIC_DEV_LOGIN="true"

# AIQFome V2
AIQFOME_API_BASE_URL="https://api.aiqfome.com"
# GET /api/v2/store (lista lojas do token) — após OAuth Magalu o id vem daqui
AIQFOME_PLATFORM_BASE_URL="https://plataforma.aiqfome.com"
# Token global (só para scripts com default_aiqfome_client). Com login Magalu, horários/cardápio NÃO usam isto.
AIQFOME_ACCESS_TOKEN=""
# Login dev: ID da loja na aiqfome (GET /api/v2/store) para `Store.externalStoreId` — senão vira "default-store"
AIQFOME_DEV_EXTERNAL_STORE_ID=""
# true = mock de menu (UUIDs fictícios). Promo real na plataforma: false + novo preparePromoApply.
AIQFOME_DRY_RUN="true"
# Desliga escrita real mesmo com cliente implementado
ENABLE_PROMO_WRITE="false"

# Temporal — orquestração (worker em Python em temporal/)
USE_TEMPORAL="true"
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"
TEMPORAL_TASK_QUEUE="liquida-promo"
# Mesmo valor no Next e no worker Python (Authorization: Bearer … em /api/internal/temporal)
TEMPORAL_INTERNAL_SECRET="troque-por-segredo-longo-aleatorio"
# Base URL do Next vista pelo worker (em container Docker use host.docker.internal)
NEXT_APP_URL="http://localhost:3000"
# Horas entre cada renovação em lote dos tokens Magalu (workflow `oauthTokenRefreshWorkflow`)
OAUTH_REFRESH_INTERVAL_HOURS="5"
