# Monorepo: normalmente copiar da raiz (.env.example) para ../.env.local
# Repo só backend: use este arquivo aqui em backend/.env.local

DATABASE_URL="postgresql://liquida:liquida@localhost:5432/liquida?schema=public"
TOKEN_ENCRYPTION_KEY="0102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f20"

MAGALU_CLIENT_ID=""
MAGALU_CLIENT_SECRET=""
MAGALU_REDIRECT_URI="http://localhost:3000/auth/magalu/callback"

# Só afeta login **sem** code. Com code Magalu, troca OAuth real.
SKIP_OAUTH_VALIDATION="false"
NODE_ENV="development"

AIQFOME_API_BASE_URL="https://api.aiqfome.com"
AIQFOME_PLATFORM_BASE_URL="https://plataforma.aiqfome.com"
AIQFOME_ACCESS_TOKEN=""
# Login dev (SKIP_OAUTH_VALIDATION): ID numérico da loja na plataforma → Store.externalStoreId
AIQFOME_DEV_EXTERNAL_STORE_ID=""
# true = mock de menu (UUIDs fictícios). Para Temporal aplicar promo na plataforma real: false + prepare de novo.
AIQFOME_DRY_RUN="true"
ENABLE_PROMO_WRITE="false"

USE_TEMPORAL="true"
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"
TEMPORAL_TASK_QUEUE="liquida-promo"
TEMPORAL_INTERNAL_SECRET="troque-por-segredo-longo-aleatorio"
# Intervalo (horas) do workflow global que renova tokens Magalu de todas as lojas
OAUTH_REFRESH_INTERVAL_HOURS="5"
