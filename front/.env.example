# Monorepo: prefira `.env.local` na raiz do repositório (um nível acima).
# Em repo só do front, use este arquivo na raiz do front.

# Proxy: URL absoluta do FastAPI (sempre com http:// ou https://). Produção: https://teu-backend.up.railway.app
API_PROXY_URL="http://127.0.0.1:8000"

# Magalu + postMessage (browser). Em produção inclua o domínio exato do Geraldo (ex.: .com).
NEXT_PUBLIC_MAGALU_CLIENT_ID=""
NEXT_PUBLIC_MAGALU_REDIRECT_URI="http://localhost:3000/auth/magalu/callback"
NEXT_PUBLIC_POSTMESSAGE_ORIGINS="https://geraldo-restaurantes.aiqfome.digital,http://localhost:3000"

# Opcional: origens que podem chamar /api/* com credentials (CORS). Se vazio, usa NEXT_PUBLIC_POSTMESSAGE_ORIGINS.
# CORS_ALLOWED_ORIGINS="https://geraldo-restaurantes.aiqfome.com"

# CSP — iframe
ALLOWED_FRAME_ANCESTORS="'self' https://geraldo-restaurantes.aiqfome.digital"

NEXT_PUBLIC_DEV_LOGIN="true"

# true = console.info em fetch /api/* (home) — só para diagnosticar proxy em prod
NEXT_PUBLIC_DEBUG_API="false"
